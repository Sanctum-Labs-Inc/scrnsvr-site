  <script is:inline>
    document.addEventListener('DOMContentLoaded', function () {
      var gate = document.getElementById('gate');
      var form = document.getElementById('gate-form');
      var pass = document.getElementById('gate-pass');
      var deck = document.getElementById('deck');
      var deckScroll = document.getElementById('deck-scroll');
      var overlay = document.querySelector('.logo-overlay');
      var logo = document.getElementById('logo');
      var circle = document.getElementById('circle');
      var PASSWORD = 'iloveyou';
      var unlocked = false;

      // ----- stop the clouds sketch (global p5 mode) and start hypertorus -----
      function stopClouds() {
        try { if (typeof window.noLoop === 'function') window.noLoop(); } catch (e) {}
        var main = document.querySelector('body > main');
        if (main) main.style.display = 'none';
      }
      var artStarted = false;
      function startDeckArt() {
        if (artStarted) return;
        artStarted = true;
        if (typeof window.startHiddenMessage === 'function') window.startHiddenMessage();
      }

      // ----- progress dots -----
      var slides = Array.prototype.slice.call(document.querySelectorAll('.slide'));
      var nav = document.getElementById('deck-nav');
      slides.forEach(function (s, i) {
        var b = document.createElement('button');
        b.type = 'button';
        b.setAttribute('aria-label', 'Go to slide ' + (i + 1));
        b.addEventListener('click', function () {
          s.scrollIntoView({ behavior: 'smooth' });
        });
        nav.appendChild(b);
      });
      var dots = Array.prototype.slice.call(nav.children);
      var prevBtn = document.getElementById('deck-prev');
      var nextBtn = document.getElementById('deck-next');
      var counter = document.getElementById('deck-counter');
      var total = slides.length;
      var current = 0;

      // Each slide has its own URL: /deck/<n> (1-based). The first slide
      // (Welcome) is /deck/1.
      function slideFromPath() {
        var m = location.pathname.match(/\/deck\/(\d+)/);
        if (!m) return 0;
        return Math.max(0, Math.min(total - 1, parseInt(m[1], 10) - 1));
      }
      function setSlideURL(idx) {
        var path = '/deck/' + (idx + 1);
        if (location.pathname !== path) {
          try { history.replaceState(null, '', path); } catch (e) {}
        }
      }
      function setActive(idx, updateURL) {
        current = idx;
        dots.forEach(function (d, i) { d.classList.toggle('is-active', i === idx); });
        if (prevBtn) prevBtn.disabled = (idx <= 0);
        if (nextBtn) nextBtn.disabled = (idx >= total - 1);
        if (counter) counter.textContent = (idx + 1) + ' / ' + total;
        if (updateURL && unlocked) setSlideURL(idx);
      }

      if ('IntersectionObserver' in window) {
        var io = new IntersectionObserver(function (entries) {
          entries.forEach(function (e) {
            if (e.isIntersecting) setActive(slides.indexOf(e.target), true);
          });
        }, { root: deckScroll, threshold: 0.55 });
        slides.forEach(function (s) { io.observe(s); });
      }

      function goTo(idx, smooth) {
        idx = Math.max(0, Math.min(total - 1, idx));
        slides[idx].scrollIntoView({ behavior: smooth ? 'smooth' : 'auto' });
        setActive(idx, true);
      }
      function go(delta) { goTo(current + delta, true); }

      if (prevBtn) prevBtn.addEventListener('click', function () { if (unlocked) go(-1); });
      if (nextBtn) nextBtn.addEventListener('click', function () { if (unlocked) go(1); });

      // Keep the active slide (and URL) synced to free scrolling/swiping.
      deckScroll.addEventListener('scroll', function () {
        window.requestAnimationFrame(function () {
          var idx = Math.round(deckScroll.scrollTop / window.innerHeight);
          setActive(Math.max(0, Math.min(total - 1, idx)), true);
        });
      }, { passive: true });

      document.addEventListener('keydown', function (e) {
        if (!unlocked) return;
        if (e.key === 'ArrowDown' || e.key === 'ArrowRight' || e.key === 'PageDown' || e.key === ' ') { e.preventDefault(); go(1); }
        else if (e.key === 'ArrowUp' || e.key === 'ArrowLeft' || e.key === 'PageUp') { e.preventDefault(); go(-1); }
        else if (e.key === 'Home') { e.preventDefault(); goTo(0, true); }
        else if (e.key === 'End') { e.preventDefault(); goTo(total - 1, true); }
      });

      // Back/forward or a manually edited URL jumps to that slide.
      window.addEventListener('popstate', function () {
        if (unlocked) goTo(slideFromPath(), false);
      });

      // ----- reveal the deck (with or without the zoom) -----
      function revealDeck(animate) {
        deck.setAttribute('aria-hidden', 'false');
        startDeckArt();
        if (animate) {
          // small delay (not rAF — throttled when the tab isn't painting) so the
          // visibility/opacity transition has a frame to animate from.
          window.setTimeout(function () { deck.classList.add('is-live'); }, 30);
          // hand off from clouds after the crossfade has begun
          window.setTimeout(stopClouds, 1300);
        } else {
          deck.style.transition = 'none';
          deck.classList.add('is-live');
          stopClouds();
        }
        unlocked = true;
      }

      // ----- the zoom (mirrors the landing page) -----
      function triggerZoom() {
        var circleRect = circle.getBoundingClientRect();
        var cx = circleRect.left + circleRect.width / 2;
        var cy = circleRect.top + circleRect.height / 2;
        var circleRadius = Math.max(circleRect.width, circleRect.height) / 2;
        var viewDiag = Math.sqrt(
          window.innerWidth * window.innerWidth + window.innerHeight * window.innerHeight
        );
        var scale = (viewDiag / circleRadius) * 1.2;
        overlay.style.transformOrigin = cx + 'px ' + cy + 'px';
        overlay.style.transform = 'scale(' + scale + ')';
      }

      function unlock() {
        if (unlocked) return;
        unlocked = true;
        try { sessionStorage.setItem('deckUnlocked', '1'); } catch (e) {}
        // Drop the keyboard first and release the keyboard anchor, then let the
        // viewport settle back to full height before the zoom is computed — so
        // the zoom origin lands on the circle, not a keyboard-shrunk viewport.
        pass.blur();
        gate.style.transform = '';
        form.classList.add('is-out');
        window.setTimeout(function () {
          triggerZoom();
          // begin crossfade partway through the zoom so the bloom lands on the deck
          window.setTimeout(function () {
            gate.classList.add('is-hidden');
            revealDeck(true);
            // land on the first slide → /deck/1
            setActive(0, true);
          }, 900);
        }, 450);
      }

      // already unlocked this session → skip the gate, open the slide in the URL
      var already = false;
      try { already = sessionStorage.getItem('deckUnlocked') === '1'; } catch (e) {}
      if (already) {
        gate.style.display = 'none';
        revealDeck(false);
        var target = slideFromPath();
        window.setTimeout(function () { goTo(target, false); }, 50);
      }

      form.addEventListener('submit', function (e) {
        e.preventDefault();
        if (unlocked) return;
        if (pass.value.trim().toLowerCase() === PASSWORD) {
          unlock();
        } else {
          form.classList.remove('is-wrong');
          // reflow so the shake re-triggers on repeated wrong tries
          void form.offsetWidth;
          form.classList.add('is-wrong');
          pass.value = '';
        }
      });
      form.addEventListener('input', function () {
        form.classList.remove('is-wrong');
      });

      // ----- iOS keyboard handling -----
      // The layout viewport must never scroll: that scroll is what dragged the
      // cloud background and logo up. Instead we pin the page at 0 and lift the
      // whole gate (logo + field, as one unit) just enough to seat the field a
      // few px above the keyboard. The clouds sit outside #gate, so they stay.
      var vv = window.visualViewport;
      function anchorAboveKeyboard() {
        if (!vv || unlocked) return;
        if (window.pageYOffset) window.scrollTo(0, 0);
        var keyboard = window.innerHeight - vv.height - (vv.offsetTop || 0);
        if (keyboard > 120 && document.activeElement === pass) {
          // Measure the field's resting bottom (no lift), then translate the
          // gate up by just the overlap so it sits ~16px above the keyboard.
          gate.style.transform = 'none';
          var bottom = form.getBoundingClientRect().bottom;
          var lift = Math.min(0, (vv.offsetTop || 0) + vv.height - 16 - bottom);
          gate.style.transform = 'translate3d(0,' + Math.round(lift) + 'px,0)';
        } else {
          gate.style.transform = '';
        }
      }
      if (vv) {
        vv.addEventListener('resize', anchorAboveKeyboard);
        vv.addEventListener('scroll', anchorAboveKeyboard);
      }
      pass.addEventListener('focus', function () {
        window.setTimeout(anchorAboveKeyboard, 60);
      });
      pass.addEventListener('blur', function () {
        gate.style.transform = '';
        window.scrollTo(0, 0);
      });

      // focus the field once it has faded in
      window.setTimeout(function () { if (!already) pass.focus(); }, 1400);
    });
  </script>
